# Variables de entorno para ContaVisión ERP Backend
# Copiar este archivo a .env y ajustar valores

DB_HOST=localhost
DB_PORT=3306
DB_NAME=contavision_erp
DB_USER=contavision_user
DB_PASSWORD=YOUR_SECURE_PASSWORD_HERE

JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRE_HOURS=8

MONTE_CARLO_URL=http://localhost:8000

UPLOAD_DIR=uploads/extractos
LOG_DIR=logs
